# Server
PORT=3000
# 'development' locally, 'production' when deployed (enables HTTPS-only cookies).
NODE_ENV=development
# A long random string used to sign session cookies. Change this!
SESSION_SECRET=change-me-to-a-long-random-string

# Public base URL of your deployed app, no trailing slash. Used to build the
# OAuth callback automatically. Leave blank for local dev (uses localhost).
#   e.g. https://the-third-world.onrender.com
PUBLIC_URL=

# Google OAuth 2.0 credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: override the callback URL explicitly. If unset, it is derived from
# PUBLIC_URL (production) or localhost (dev).
# Local dev:  http://localhost:3000/auth/google/callback
# Production: https://yourdomain.com/auth/google/callback
# GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
